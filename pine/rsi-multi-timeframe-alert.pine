//@version=5
indicator("RSI Ultra Signal", overlay=true, format=format.price, precision=2)

// ═══════════════════════════════════════════════════════════════
// RSI ULTRA SIGNAL — Professional Grade Multi-Indicator System
// ═══════════════════════════════════════════════════════════════
// Combines 6 confirmations for ULTRA-RELIABLE signals:
//   ✅ RSI Oversold/Overbought (base)
//   ✅ MACD Trend Confirmation
//   ✅ EMA 200 Alignment
//   ✅ Volume Surge Detection
//   ✅ Hidden & Regular Divergence
//   ✅ Multi-Timeframe Confluence (min 2 TFs)
//   ✅ Signal Strength Scoring (1-5 Stars)
// Signals below minStarRating are automatically filtered.
// ═══════════════════════════════════════════════════════════════

// ───────── RSI ─────────
rsiLength = input.int(14, "RSI Period", group="RSI")
rsiOb = input.int(70, "Overbought Level", group="RSI")
rsiOs = input.int(30, "Oversold Level", group="RSI")

// ───────── Timeframes ─────────
tf1 = input.timeframe("5", "TF1 Fast", group="Timeframes")
tf2 = input.timeframe("15", "TF2", group="Timeframes")
tf3 = input.timeframe("60", "TF3 Medium", group="Timeframes")
tf4 = input.timeframe("240", "TF4 Slow", group="Timeframes")
tf5 = input.timeframe("D", "TF5 Daily", group="Timeframes")

// ───────── Filters ─────────
useMacd = input.bool(true, "MACD Confirm", group="Confluence")
useEma = input.bool(true, "200 EMA Filter", group="Confluence")
useVolume = input.bool(true, "Volume Surge", group="Confluence")
useDivergence = input.bool(true, "Divergence", group="Confluence")
useMultiTf = input.bool(true, "Multi-TF Confirm", group="Confluence")
minStars = input.int(3, "Min Stars (1-5)", minval=1, maxval=5, group="Confluence")

// ───────── Alerts ─────────
minInterval = input.int(60, "Min Interval (min)", group="Alerts")
alertBuy = input.bool(true, "Buy Signals", group="Alerts")
alertSell = input.bool(true, "Sell Signals", group="Alerts")

// ═══════════════════════════════
// HELPERS
// ═══════════════════════════════

tfClose(tf) => request.security(syminfo.tickerid, tf, close)
tfVolume(tf) => request.security(syminfo.tickerid, tf, volume)

calcRsi(tf, len) => ta.rsi(tfClose(tf), len)

calcMacd(tf) =>
    [m, s, _] = request.security(syminfo.tickerid, tf, ta.macd(close, 12, 26, 9))
    [m, s]

calcEma200(tf) => ta.ema(tfClose(tf), 200)

volSurge(tf) =>
    v = tfVolume(tf)
    v > ta.sma(v, 20) * 1.5

// ═══════════════════════════════
// INDICATORS FOR ALL TFs
// ═══════════════════════════════

rsi(tf) => calcRsi(tf, rsiLength)
ema200(tf) => calcEma200(tf)

r1=rsi(tf1); r2=rsi(tf2); r3=rsi(tf3); r4=rsi(tf4); r5=rsi(tf5)
[m1,s1]=calcMacd(tf1); [m2,s2]=calcMacd(tf2); [m3,s3]=calcMacd(tf3); [m4,s4]=calcMacd(tf4); [m5,s5]=calcMacd(tf5)
e1=ema200(tf1); e2=ema200(tf2); e3=ema200(tf3); e4=ema200(tf4); e5=ema200(tf5)
c1=tfClose(tf1); c2=tfClose(tf2); c3=tfClose(tf3); c4=tfClose(tf4); c5=tfClose(tf5)

// ═══════════════════════════════
// DETECT SIGNAL PER TIMEFRAME
// ═══════════════════════════════

detect(tfRsi, tfMacd, tfSignal, tfEma, tfC) =>
    ob = ta.crossover(tfRsi, rsiOb); os = ta.crossunder(tfRsi, rsiOs)
    b=0.0; s=0.0; br=""; sr=""

    if os
        b+=1; br+="RSI_OS "
    if ob
        s+=1; sr+="RSI_OB "
    if tfRsi<rsiOs and not os
        b+=0.5
    if tfRsi>rsiOb and not ob
        s+=0.5

    if useMacd
        mBull=ta.crossover(tfMacd,tfSignal) and tfMacd<0
        mBear=ta.crossunder(tfMacd,tfSignal) and tfMacd>0
        if mBull
            b+=1; br+="MACD_Bull "
        if mBear
            s+=1; sr+="MACD_Bear "

    if useEma
        if tfC>tfEma
            s+=0.5
        else
            b+=0.5

    if useVolume
        if volSurge(tf1)
            b+=0.5; s+=0.5

    if useDivergence
        if tfC<tfC[10] and tfRsi>tfRsi[10]
            b+=1.5; br+="Div_Bull "
        if tfC>tfC[10] and tfRsi<tfRsi[10]
            s+=1.5; sr+="Div_Bear "

    [b,s,br,sr]

[b1,s1b,rb1,rs1]=detect(r1,m1,s1,e1,c1)
[b2,s2b,rb2,rs2]=detect(r2,m2,s2,e2,c2)
[b3,s3b,rb3,rs3]=detect(r3,m3,s3,e3,c3)
[b4,s4b,rb4,rs4]=detect(r4,m4,s4,e4,c4)
[b5,s5b,rb5,rs5]=detect(r5,m5,s5,e5,c5)

// ═══════════════════════════════
// AGGREGATE
// ═══════════════════════════════

totalB = b1+b2+b3+b4+b5
totalS = s1b+s2b+s3b+s4b+s5b

bTf = (b1>=2?1:0)+(b2>=2?1:0)+(b3>=2?1:0)+(b4>=2?1:0)+(b5>=2?1:0)
sTf = (s1b>=2?1:0)+(s2b>=2?1:0)+(s3b>=2?1:0)+(s4b>=2?1:0)+(s5b>=2?1:0)

if useMultiTf
    if bTf>=2
        totalB+=1.5
    if bTf>=3
        totalB+=1
    if sTf>=2
        totalS+=1.5
    if sTf>=3
        totalS+=1

finalB = totalB>=minStars and totalB>totalS and alertBuy
finalS = totalS>=minStars and totalS>totalB and alertSell

// ═══════════════════════════════
// ALERT
// ═══════════════════════════════

var lastAlert=0
alertNow = (finalB or finalS) and (time-lastAlert)/60000 >= minInterval

if alertNow
    lastAlert:=time
    dir = finalB ? "BUY" : "SELL"
    st = finalB ? totalB : totalS
    tfc = finalB ? bTf : sTf
    rsiVals = str.tostring(r1,"#.#")+" | "+str.tostring(r2,"#.#")+" | "+str.tostring(r3,"#.#")+" | "+str.tostring(r4,"#.#")+" | "+str.tostring(r5,"#.#")
    reasons = finalB ? rb1+rb2+rb3+rb4+rb5 : rs1+rs2+rs3+rs4+rs5
    msg = dir+" | "+syminfo.tickerid+"\nStars: "+str.tostring(st,"#.#")+"/5\nRSI: "+rsiVals+"\nTFs: "+str.tostring(tfc)+"/5\n"+reasons+"\nPrice: "+str.tostring(close,"#.#####")+"\n"+str.format("{0,date,yyyy-MM-dd HH:mm}",timenow)
    alert(msg, alert.freq_once_per_bar_close)

// ═══════════════════════════════
// VISUALS
// ═══════════════════════════════

hline(rsiOb, color=color.new(#ff4444,60), linestyle=hline.style_dashed)
hline(50, color=color.new(#888,40), linestyle=hline.style_dotted)
hline(rsiOs, color=color.new(#44ff44,60), linestyle=hline.style_dashed)

plot(r1, "TF1", color.new(#2196F3,20), 3)
plot(r2, "TF2", color.new(#9C27B0,30), 2)
plot(r3, "TF3", color.new(#FF9800,40), 2)
plot(r4, "TF4", color.new(#F44336,50), 1.5)
plot(r5, "TF5", color.new(#607D8B,60), 1)

plotshape(finalB, "", shape.triangleup, location.belowbar, color.new(#00FF00,40), size=size.large)
plotshape(finalS, "", shape.triangledown, location.abovebar, color.new(#FF0000,40), size=size.large)

if finalB
    label.new(bar_index, low, str.tostring(totalB,"#.#")+"★", style=label.style_label_up, color=color.new(#00FF00,60), textcolor=color.black, size=size.small)
if finalS
    label.new(bar_index, high, str.tostring(totalS,"#.#")+"★", style=label.style_label_down, color=color.new(#FF0000,60), textcolor=color.white, size=size.small)

bgcolor(r1>rsiOb?color.new(#FF0000,85):na)
bgcolor(r1<rsiOs?color.new(#00FF00,85):na)
